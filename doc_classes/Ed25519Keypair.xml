<?xml version="1.0" encoding="UTF-8" ?>
<class name="Ed25519Keypair" inherits="RefCounted" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/godotengine/godot/master/doc/class.xsd">
	<brief_description>
		A container for Ed25519 key pairs.
	</brief_description>
	<description>
		This class holds an Ed25519 public and private key pair. It is typically returned by [method generate] or [method from_private_key].
	</description>
	<tutorials>
	</tutorials>
	<methods>
		<method name="generate" qualifiers="static">
			<return type="Ed25519Keypair" />
			<description>
				Generates a new Ed25519 keypair using cryptographically secure random bytes from [method OS.get_entropy]. Returns an [Ed25519Keypair] object containing the public and private keys. The private key is the raw 32-byte seed.
			</description>
		</method>
		<method name="from_private_key" qualifiers="static">
			<return type="Ed25519Keypair" />
			<param index="0" name="private_key" type="PackedByteArray" />
			<description>
				Creates and returns a new [Ed25519Keypair] from an existing 32-byte private key (seed). Returns an empty keypair if the provided key size is invalid.
			</description>
		</method>
		<method name="get_private_key" qualifiers="const">
			<return type="PackedByteArray" />
			<description>
				Returns the 32-byte private key (seed).
			</description>
		</method>
		<method name="get_public_key" qualifiers="const">
			<return type="PackedByteArray" />
			<description>
				Returns the 32-byte public key.
			</description>
		</method>
		<method name="set_private_key">
			<return type="void" />
			<param index="0" name="private_key" type="PackedByteArray" />
			<description>
				Sets the private key.
			</description>
		</method>
		<method name="set_public_key">
			<return type="void" />
			<param index="0" name="public_key" type="PackedByteArray" />
			<description>
				Sets the public key.
			</description>
		</method>
	</methods>
	<members>
		<member name="private_key" type="PackedByteArray" setter="set_private_key" getter="get_private_key" default="PackedByteArray()">
			The 32-byte private key (seed).
		</member>
		<member name="public_key" type="PackedByteArray" setter="set_public_key" getter="get_public_key" default="PackedByteArray()">
			The 32-byte public key.
		</member>
	</members>
</class>
